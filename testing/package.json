{
  "name": "phaser-tutorial-testing",
  "version": "1.0.0",
  "description": "Testing system for Phaser.js tutorial handbook",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:content": "node src/contentValidator.js",
    "test:examples": "node src/exampleValidator.js",
    "test:browser": "playwright test",
    "test:learning": "node src/learningEffectiveness.js",
    "test:all": "npm run test:content && npm run test:examples && npm run test:browser && npm run test",
    "report": "node src/reportGenerator.js"
  },
  "dependencies": {
    "puppeteer": "^21.5.2",
    "playwright": "^1.40.0",
    "jsdom": "^23.0.1",
    "marked": "^11.1.1",
    "highlight.js": "^11.9.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "vitest": "^1.0.4",
    "@playwright/test": "^1.40.0"
  }
}